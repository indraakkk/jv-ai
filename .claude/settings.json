{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/require-rtk.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-nix-build.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/compaction-gate.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/inject-reminders.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/verify-import-order.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/verify-db-constraints.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/auto-nix-eval.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/agent-stop-guard.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-stop-guard.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__serena__read_memory",
      "mcp__serena__write_memory",
      "mcp__serena__edit_memory",
      "mcp__serena__list_memories",
      "mcp__serena__list_dir",
      "mcp__serena__find_file",
      "mcp__serena__find_symbol",
      "mcp__serena__get_symbols_overview",
      "mcp__serena__search_for_pattern",
      "mcp__serena__check_onboarding_performed",
      "mcp__serena__initial_instructions",
      "mcp__serena__think_about_task_adherence",
      "mcp__serena__think_about_collected_information",
      "mcp__serena__think_about_whether_you_are_done",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:biomejs.dev)",
      "WebFetch(domain:effect.website)",
      "WebFetch(domain:tanstack.com)",
      "WebFetch(domain:nixos.org)",
      "WebFetch(domain:nixos.wiki)",
      "Bash(git status:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git fetch:*)",
      "Bash(git rebase:*)",
      "Bash(git checkout:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git log:*)",
      "Bash(git mv:*)",
      "Bash(git push:*)",
      "Bash(git worktree:*)",
      "Bash(git check-ignore:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr view:*)",
      "Bash(gh api:*)",
      "Bash(nix build:*)",
      "Bash(nix flake show:*)",
      "Bash(nix flake check:*)",
      "Bash(nix flake metadata:*)",
      "Bash(nix flake update:*)",
      "Bash(nix flake prefetch:*)",
      "Bash(nix flake archive:*)",
      "Bash(nix eval:*)",
      "Bash(nix log:*)",
      "Bash(nix fmt:*)",
      "Bash(nix develop:*)",
      "Bash(nix repl:*)",
      "Bash(nix derivation show:*)",
      "Bash(nix path-info:*)",
      "Bash(nix-build:*)",
      "Bash(nix-instantiate:*)",
      "Bash(nix-store:*)",
      "Bash(ssh:*)",
      "Bash(curl:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(pgrep:*)",
      "Bash(tee:*)",
      "Bash(echo:*)",
      "Bash(chmod:*)",
      "Bash(ping:*)",
      "Bash(ping6:*)",
      "Bash(dig:*)",
      "Bash(host:*)",
      "Bash(nslookup:*)",
      "Bash(scutil:*)",
      "Bash(rtk:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "serena"
  ]
}
