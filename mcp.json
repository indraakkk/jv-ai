{
  "mcpServers": {
    "serena": {
      "type": "stdio",
      "command": "serena",
      "args": [
        "start-mcp-server",
        "--context",
        "claude-code",
        "--project-from-cwd"
      ],
      "env": {}
    },
    "jackson-ventures": {
      "type": "stdio",
      "command": "bun",
      "args": ["run", "packages/mcp-server/src/index.ts"],
      "env": {}
    }
  }
}
